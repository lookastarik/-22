{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and strategic roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User profile picture URL" },
        "role": { "type": "string", "enum": ["anonymous", "investor", "admin"], "description": "Strategic authority level" },
        "balance": { "type": "number", "description": "Current treasury balance" },
        "portfolio": { "type": "array", "items": { "type": "number" }, "description": "List of acquired asset IDs" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of account initialization" }
      },
      "required": ["uid", "email", "role"]
    },
    "assets": {
      "title": "Real Estate Asset",
      "description": "Represents a real estate object or GAB (Ready Rental Business).",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique asset identifier" },
        "title": { "type": "string", "description": "Name of the asset" },
        "address": { "type": "string", "description": "Physical address" },
        "latitude": { "type": "number", "description": "Map latitude" },
        "longitude": { "type": "number", "description": "Map longitude" },
        "cost": { "type": "number", "description": "Total acquisition cost" },
        "yield": { "type": "number", "description": "Monthly rental income" },
        "roi": { "type": "number", "description": "Return on Investment percentage" },
        "status": { "type": "number", "enum": [0, 1, 2], "description": "0: Stable, 1: Risk, 2: Anomalous" },
        "type": { "type": "string", "enum": ["retail", "office", "warehouse", "residential"], "description": "Asset category" },
        "ownerUid": { "type": "string", "description": "UID of the asset creator/owner" },
        "sqft": { "type": "number", "description": "Total square footage of the asset" },
        "yearBuilt": { "type": "number", "description": "The year the structure was completed" },
        "parkingSpaces": { "type": "number", "description": "Number of available parking slots" },
        "description": { "type": "string", "description": "Detailed asset briefing" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of asset creation" }
      },
      "required": ["title", "latitude", "longitude", "cost", "ownerUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Collection of strategic user profiles."
    },
    "/assets/{assetId}": {
      "schema": "assets",
      "description": "Collection of real estate assets and GABs."
    }
  }
}
